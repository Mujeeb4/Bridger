<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules for Android 12+ (API 31+).
    Controls what data is included in cloud backups and device-to-device transfers.
    
    Only include app preferences and databases.
    Everything else (files with encryption keys, certificates, etc.) 
    is excluded by only specifying include rules (implicit deny all).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
