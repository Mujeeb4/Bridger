<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Bridger</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Bridger</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	
	<!-- Privacy Permissions -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Bridger needs Bluetooth to connect with your Android device for SMS, calls, and notifications.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Bridger needs Bluetooth to maintain connection with your Android device.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Bridger needs local network access to communicate with your Android device via Wi-Fi.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Bridger needs microphone access to make and receive phone calls through your Android device.</string>
	<key>NSCameraUsageDescription</key>
	<string>Bridger needs camera access to scan QR code for device pairing.</string>
	<key>NSContactsUsageDescription</key>
	<string>Bridger needs access to contacts to display caller information.</string>
	
	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>voip</string>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.pravera.flutter_foreground_task.refresh</string>
	</array>

	<!-- CallKit -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- Audio Session -->
	<key>UIRequiresPersistentWiFi</key>
	<true/>
	
	<!-- Status Bar -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	
	<!-- Export Compliance (uses AES-256-GCM encryption) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<true/>
	<key>ITSEncryptionExportComplianceCode</key>
	<string></string>
	
	<!-- App Transport Security - allow local cleartext WebSocket -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	
	<!-- Required Device Capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>bluetooth-le</string>
		<string>armv7</string>
		<string>microphone</string>
	</array>
	
	<!-- Bonjour Services (required for local network browsing on iOS 14+) -->
	<key>NSBonjourServices</key>
	<array>
		<string>_bridgephone._tcp</string>
	</array>
</dict>
</plist>
